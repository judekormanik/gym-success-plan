# ─── Stripe ───────────────────────────────────────────
# Publishable key is exposed to the client; secret/webhook keys stay server-side
# in Cloudflare Pages env vars.
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your_key_here
STRIPE_SECRET_KEY=sk_live_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# ─── App ──────────────────────────────────────────────
VITE_APP_URL=https://yourdomain.com

# ─── Auth ─────────────────────────────────────────────
# A long random string used to sign session cookies (HMAC-SHA256).
# Generate one with: openssl rand -base64 48
AUTH_SECRET=replace_with_a_long_random_string

# ─── D1 ───────────────────────────────────────────────
# No env vars needed — D1 is bound via wrangler.toml as `env.DB` inside Functions.
