{
  "name": "the-gym-success-plan",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "The Gym Success Plan — a fitness tracking and community platform.",
  "scripts": {
    "dev": "vite",
    "build:exercises": "node scripts/build-exercises.mjs",
    "build:usda": "node scripts/build-usda.mjs",
    "prebuild": "npm run build:exercises && npm run build:usda",
    "build": "vite build",
    "preview": "vite preview",
    "db:create": "wrangler d1 create gym-success-plan",
    "db:apply": "wrangler d1 execute gym-success-plan --remote --file=schema.sql",
    "db:apply:local": "wrangler d1 execute gym-success-plan --local --file=schema.sql",
    "deploy": "npm run build && wrangler pages deploy dist --project-name=gym-success-plan"
  },
  "dependencies": {
    "framer-motion": "^11.11.1",
    "lucide-react": "^0.453.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "recharts": "^2.13.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.2",
    "vite": "^5.4.8",
    "wrangler": "^4.88.0"
  }
}
